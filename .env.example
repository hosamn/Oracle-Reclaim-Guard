# Copy this file to .env and fill in real values. Never commit the real .env.

# Required
COMPARTMENT_ID=ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_TOKEN=your-telegram-bot-token
Chat_UID=your-telegram-chat-id

# Optional
OCI_CONFIG_PROFILE=DEFAULT
REGION=
INCLUDE_SUBCOMPARTMENTS=true
DEFAULT_MAX_MBITS=50

# Optional per-shape network bandwidth overrides (Mbps).
# Uncomment and adjust shape name to match your instance's exact OCI shape string.
# MAX_MBITS_VM_STANDARD_A1_FLEX=1000
# MAX_MBITS_VM_STANDARD_E2_1_MICRO=50
